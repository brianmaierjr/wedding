---
import Card from "./Card.astro";
import { getEventData } from "../data/eventData";

const { cards = [] } = getEventData();
---

<section class="max-w-4xl mx-auto my-16 px-4">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 place-items-center">
        {
            cards.map((card) => (
                <Card
                    image={card.image}
                    imageAlt={card.imageAlt}
                    title={card.title}
                    description={card.description}
                    buttons={card.buttons}
                />
            ))
        }
    </div>
</section>
